graph LR
    subgraph ACQ["📷 ACQUISITION"]
        IMG["Raw RGB Image
        (variable resolution)"]
        CTX["Context
        (timestamp, seam type,
        camera ID, criticality)"]
    end

    subgraph PREP["🔧 PREPROCESSOR"]
        CLEAN["→ Resize
        → Normalize
        → Color convert
        → Exposure correct"]
        QC{"Quality
        Check"}
    end

    subgraph AI["🧠 AI COMPONENT"]
        BB["Backbone CNN
        (light enough so
        < 1/12s inference)"]
        LS["LATENT
        SPACE"]
        PR["Predictor P(OK) / P(NOK) /
        P(Unknown)"]
        UQ["Uncertainty
        Quantifier"]
        OOD["OOD
        Detector"]
    end

    subgraph MA["📊 METRICS ASSEMBLY"]
        CRIT["Criticality\nAdjustment"]
        DEC{"Decision\nRules"}
        FO["✅ Final Class\nOK / NOK / Unknown"]
        AO["📋 Trust Info\nconfidence, OOD score,\nrationale"]
    end

    subgraph OP["🖥️ OPERATOR"]
        DISP["OP 120\nDisplay"]
        FB["Operator\nFeedback"]
    end

    subgraph MON["📈 MONITORING"]
        TRACK["Online\nMonitoring"]
        DB[("Storage")]
        BATCH["Batch\nControl"]
    end

    IMG --> CLEAN --> QC
    QC -->|"✅ OK"| BB
    QC -->|"❌ Unusable"| DEC
    BB --> LS
    LS --> PR
    LS --> UQ
    LS --> OOD
    PR --> DEC
    UQ --> DEC
    OOD --> DEC
    CTX --> CRIT --> DEC
    DEC --> FO
    DEC --> AO
    FO --> DISP
    AO --> DISP
    DISP --> FB
    FO --> TRACK
    AO --> TRACK
    TRACK --> DB
    DB --> BATCH
    FB --> DB

